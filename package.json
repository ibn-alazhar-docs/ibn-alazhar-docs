{
  "name": "ibn-al-azhar-docs",
  "version": "0.0.0",
  "private": true,
  "description": "Arabic-first, RTL-first document processing workspace for Ibn Al-Azhar Docs.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "22.x",
    "pnpm": "10.33.4"
  },
  "scripts": {
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit && tsc -p packages/pipeline/tsconfig.json --noEmit && tsc -p workers/ocr-worker/tsconfig.json --noEmit && tsc -p workers/export-worker/tsconfig.json --noEmit && tsc -p packages/database/tsconfig.json --noEmit",
    "hooks:install": "bash scripts/setup-hooks.sh",
    "test:regression": "vitest run tests/regression/regression-suite.test.ts",
    "ci:quick": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:regression",
    "ci:full": "pnpm ci:all && pnpm test:api && pnpm test:integration && pnpm test:security && pnpm test:edge && pnpm test:fuzz",
    "ci:all": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm secrets:scan",
    "tools:doctor": "node -e \"console.log('Tooling foundation OK')\"",
    "secrets:scan": "node scripts/secrets-scan.mjs",
    "format:write": "prettier . --write",
    "lint": "eslint apps/ packages/ workers/ --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:api": "vitest run --project=api",
    "test:security": "vitest run --project=security",
    "test:frontend": "vitest run --project=frontend",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/database/prisma/schema.prisma",
    "db:seed": "npx tsx packages/database/prisma/seed.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@opennextjs/cloudflare": "1.20.1",
    "@playwright/test": "1.61.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "3.2.4",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "fast-check": "4.9.0",
    "jsdom": "25.0.1",
    "jszip": "3.10.1",
    "pg": "8.22.0",
    "prettier": "3.6.2",
    "prisma": "6.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "wrangler": "4.105.0",
    "zod": "4.4.3"
  },
  "dependencies": {
    "@prisma/client": "6.5.0",
    "@tanstack/react-query": "5.101.2",
    "googleapis": "173.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}

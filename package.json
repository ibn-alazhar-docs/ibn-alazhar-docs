{
  "name": "ibn-al-azhar-docs",
  "version": "0.0.0",
  "private": true,
  "description": "Arabic-first, RTL-first document processing workspace for Ibn Al-Azhar Docs.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "22.x",
    "pnpm": "10.33.4"
  },
  "scripts": {
    "check": "pnpm format:check && pnpm typecheck",
    "format": "prettier . --write",
    "format:check": "prettier \"AGENTS.md\" \"README.md\" \".agents/**/*.md\" \"docs/tools/**/*.md\" \"scripts/**/*.{js,mjs,ts}\" \"package.json\" \"tsconfig*.json\" --check",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit && tsc -p packages/pipeline/tsconfig.json --noEmit && tsc -p workers/ocr-worker/tsconfig.json --noEmit && tsc -p workers/export-worker/tsconfig.json --noEmit",
    "tools:doctor": "node -e \"console.log('Tooling foundation OK')\"",
    "secrets:scan": "node scripts/secrets-scan.mjs",
    "format:write": "prettier \"AGENTS.md\" \"README.md\" \".agents/**/*.md\" \"docs/tools/**/*.md\" \"scripts/**/*.{js,mjs,ts}\" \"package.json\" \"tsconfig*.json\" --write"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "typescript": "5.9.3"
  }
}

# Ibn Al-Azhar Docs — HuggingFace Spaces environment
# Copy to .env and fill in values

# ═══════════════════════════════════════════
# DATABASE (Neon — free tier)
# ═══════════════════════════════════════════
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_DIRECT="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ═══════════════════════════════════════════
# REDIS (Upstash — free tier)
# ═══════════════════════════════════════════
REDIS_URL="rediss://default:xxx@us1-merry-antlion-xxxx.upstash.io:6379"

# ═══════════════════════════════════════════
# STORAGE (MinIO — local to HF Spaces container)
# ═══════════════════════════════════════════
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="ibnalazhardocs"
S3_REGION="us-east-1"

# ═══════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
ADMIN_EMAIL="admin@ibnalazhar.app"
ADMIN_PASSWORD="your-strong-admin-password"

# ═══════════════════════════════════════════
# GOOGLE (OAuth + Gemini)
# ═══════════════════════════════════════════
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GEMINI_API_KEY=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""

# ═══════════════════════════════════════════
# APP
# ═══════════════════════════════════════════
NODE_ENV="production"
APP_URL="https://ibnalazhardocs.workers.dev"
NEXT_PUBLIC_SITE_URL="https://ibnalazhardocs.workers.dev"
APP_NAME="Ibn Al-Azhar Docs"

# ═══════════════════════════════════════════
# OCR
# ═══════════════════════════════════════════
OCR_PROVIDER="tesseract"
OCR_PROVIDERS="tesseract"
OCR_LANGUAGE="ar"
OCR_DPI=300

# ═══════════════════════════════════════════
# CLOUDFLARE (for deployment)
# ═══════════════════════════════════════════
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
HF_TOKEN=

# Ibn Al-Azhar Docs — environment example
# Never commit real secrets.

NODE_ENV=development

# App
APP_NAME="Ibn Al-Azhar Docs"
APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://ibn_docs:ibn_docs_password@localhost:5432/ibn_docs?schema=public"

# Redis / queue
REDIS_URL="redis://localhost:6379"

# Object storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ibn-docs-local"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# Auth placeholder
AUTH_SECRET="replace-with-local-dev-secret"
AUTH_TRUST_HOST=true

# AI / external tools
# Do not put Claude / Anthropic / TestSprite keys here unless using local untracked .env
TESTSPRITE_API_KEY=""

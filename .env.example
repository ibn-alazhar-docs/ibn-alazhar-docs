# Ibn Al-Azhar Docs — environment example
# Never commit real secrets.

NODE_ENV=development

# App
APP_NAME="Ibn Al-Azhar Docs"
APP_URL="http://localhost:3000"

# Database
POSTGRES_PORT=5433  # Host port for PostgreSQL (container runs on 5432)

# Required secrets (no defaults — set these before running docker compose)
POSTGRES_PASSWORD="ibn_docs_password"
REDIS_PASSWORD="redis_password"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
AUTH_SECRET="replace-with-local-dev-secret"  # REQUIRED in production (no fallback)
ADMIN_PASSWORD="Admin@123456"

# Upload limits
MAX_UPLOAD_SIZE_MB=2048  # Default: 2GB. Override via env (min: 1MB)

# Database
DATABASE_URL="postgresql://ibn_docs:ibn_docs_password@localhost:5432/ibn_docs?schema=public"
# PgBouncer connection pool (use for Prisma, keep DATABASE_URL_DIRECT for migrations)
DATABASE_URL_POOLED="postgresql://ibn_docs:ibn_docs_password@localhost:6432/ibn_docs?schema=public"

# Redis / queue
REDIS_URL="redis://:redis_password@localhost:6379"

# Queue driver: "redis" (default, BullMQ) or "pg" (Postgres-backed).
# pg mode requires DATABASE_URL + DATABASE_URL_DIRECT and does NOT use Redis.
QUEUE_DRIVER="redis"

# Object storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ibnalazhardocs"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# Auth
AUTH_TRUST_HOST=true

# Seed credentials — REQUIRED in production (no safe fallback for ADMIN/USER).
# The seed uses these to create the initial accounts. If unset, the seed falls
# back to weak hardcoded defaults (AdminPassword123! / UserPassword123!) which
# MUST NOT be used in production. TEST_ADMIN_PASSWORD falls back to a random
# value per run when unset.
ADMIN_EMAIL="admin@ibnalazhar.app"
ADMIN_PASSWORD="CHANGE_ME_strong_admin_password"
USER_PASSWORD="CHANGE_ME_strong_user_password"
TEST_ADMIN_PASSWORD="CHANGE_ME_strong_test_admin_password"

# AI / external tools
TESTSPRITE_API_KEY=""

# Monitoring (optional — only needed with monitoring stack)
GRAFANA_USER="admin"
GRAFANA_PASSWORD="grafana_password"

# Sentry (error monitoring — required in production)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Caddy (optional — only needed with Caddy reverse proxy)
DOMAIN="localhost"
EMAIL="off"
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ==============================================================================
# OCR Configuration
# ==============================================================================
# Primary OCR provider: gemini (cloud, best quality) | surya (local, fast) | tesseract (local, basic) | google (cloud, Drive API)
OCR_PROVIDER=surya
# Comma-separated fallback chain (tried in order if primary fails)
OCR_PROVIDERS=surya,tesseract
# Enable cloud providers (gemini, google) - set to true and provide API keys below
OCR_CLOUD_ENABLED=false
# Gemini API Key (get from https://aistudio.google.com/app/apikey)
# Required if OCR_PROVIDER=gemini or gemini is in OCR_PROVIDERS
GEMINI_API_KEY=
# Gemini model (gemini-1.5-flash recommended for speed/cost balance)
GEMINI_MODEL=gemini-3.5-flash
# Comma-separated fallback models tried when primary returns 503/429/overloaded
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
# Pages per native PDF chunk sent to Gemini (lower = smaller payloads, higher = fewer API calls)
GEMINI_NATIVE_CHUNK_SIZE=4
# Maximum retry attempts for failed OCR jobs
OCR_MAX_RETRIES=3
# Minimum confidence threshold (0.0-1.0) - retry with next provider if below this
OCR_MIN_CONFIDENCE=0.0
# DPI for PDF rasterization (300=standard, 400=high quality, 200=fast)
OCR_DPI=300
# Preprocessing mode: auto (smart upscale low-res pages), on (always preprocess), off (disable)
OCR_PREPROCESS_MODE=auto
# Target DPI for upscaling genuinely low-res scans (auto mode only)
OCR_TARGET_DPI=400
# Preprocessing steps: 1=enabled, 0=disabled
OCR_DESKEW=1         # Correct rotation and skew
OCR_CLAHE=1          # Contrast enhancement
OCR_DENOISE=1        # Noise reduction
OCR_SHADOW=1         # Shadow/illumination normalization
OCR_BORDER=0         # Content border cropping (off by default)
OCR_PERSPECTIVE=0    # Perspective correction (off by default)
OCR_BINARIZE=0       # Adaptive thresholding (off by default)
OCR_SHARPEN=0        # Unsharp masking (off by default)

# Google Cloud Vision / Drive OCR (optional, alternative to Gemini)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Ibn Al-Azhar Docs — environment example
# Never commit real secrets.
# Copy to .env for local development.

NODE_ENV=development

# App
APP_NAME="Ibn Al-Azhar Docs"
APP_URL="http://localhost:3000"

# Database (PostgreSQL 16)
POSTGRES_PORT=5433  # Host port for PostgreSQL (container runs on 5432)

# Required secrets (no defaults — set these before running docker compose)
POSTGRES_PASSWORD="ibn_docs_password"
REDIS_PASSWORD="redis_password"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
AUTH_SECRET="replace-with-local-dev-secret"  # REQUIRED in production (no fallback)
ADMIN_PASSWORD="Admin@123456"

# Upload limits
MAX_UPLOAD_SIZE_MB=2048  # Default: 2GB. Override via env (min: 1MB)

# Database connection URLs (host port is 5433 for local dev, see POSTGRES_PORT above)
DATABASE_URL="postgresql://ibn_docs:ibn_docs_password@localhost:5433/ibn_docs?schema=public"
DATABASE_URL_DIRECT="postgresql://ibn_docs:ibn_docs_password@localhost:5433/ibn_docs?schema=public"
DATABASE_URL_POOLED="postgresql://ibn_docs:ibn_docs_password@localhost:6432/ibn_docs?schema=public"

# Redis / queue (BullMQ + Redis 7)
REDIS_URL="redis://:redis_password@localhost:6379"

# Object storage (MinIO — S3-compatible)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ibn-al-azhar-docs"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# Auth (NextAuth.js v5 — JWT strategy, 24h maxAge)
AUTH_TRUST_HOST=true
ADMIN_EMAIL="admin@ibnalazhar.app"

# AI / external tools (never store real keys in committed files)
TESTSPRITE_API_KEY=""

# Monitoring (optional — only needed with monitoring stack)
GRAFANA_USER="admin"
GRAFANA_PASSWORD="grafana_password"

# Caddy (optional — only needed with Caddy reverse proxy)
DOMAIN="localhost"
EMAIL="off"
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

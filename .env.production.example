# =============================================================================
# متغيرات البيئة للإنتاج — Cloudflare Deployment
# تاريخ الإنشاء: 2026-07-04
# الاستخدام: انسخ هذا الملف إلى .env.production واملأ القيم
# =============================================================================

# =============================================================================
# قاعدة البيانات (Neon PostgreSQL)
# =============================================================================
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# =============================================================================
# Redis (Upstash Redis)
# =============================================================================
REDIS_URL="rediss://default:xxxxx@xxxxx.upstash.io:6379"

# =============================================================================
# التخزين السحابي (Cloudflare R2 / S3-compatible)
# أسماء المتغيرات يجب أن تطابق ما يقرأه التطبيق (packages/pipeline/src/config.ts)
# متغيّرات S3_* لها الأولوية؛ MINIO_* تُستخدم كاحتياطي (fallback) فقط
# =============================================================================
S3_ENDPOINT="https://xxxxx.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="ibn-al-azhar-docs"
S3_ACCESS_KEY_ID="xxxxx"
S3_SECRET_ACCESS_KEY="xxxxx"
# احتياطي لـ MinIO (يُستخدم فقط إن لم تُعيَّن قيم S3_* أعلاه)
# MINIO_ENDPOINT="http://minio:9000"
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="minioadmin"
# MINIO_BUCKET="ibnalazhardocs"

# =============================================================================
# المصادقة
# =============================================================================
# ولّد القيم باستخدام: openssl rand -base64 32  (لـ AUTH_SECRET) و openssl rand -base64 16 (لـ ADMIN_PASSWORD)
AUTH_SECRET=
ADMIN_PASSWORD=

# =============================================================================
# البريد الإلكتروني (Resend)
# =============================================================================
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="Ibn Al-Azhar Docs <noreply@ibnalazhardocs.workers.dev>"

# =============================================================================
# OCR Configuration (Gemini)
# Required for Arabic exam PDF processing with high quality OCR
# =============================================================================
# Primary OCR provider: gemini (cloud, best quality) | surya (local) | tesseract (local)
OCR_PROVIDER=gemini
# Comma-separated fallback chain (tried in order if primary fails)
OCR_PROVIDERS=gemini,surya,tesseract
# Enable cloud providers (gemini) - requires API key
OCR_CLOUD_ENABLED=true
# Gemini API Key (get from https://aistudio.google.com/app/apikey)
# REQUIRED: Set your actual Gemini API key for OCR to work
GEMINI_API_KEY=
# Gemini model (gemini-1.5-flash recommended for speed/cost balance)
GEMINI_MODEL=gemini-1.5-flash
# Maximum retry attempts for failed OCR jobs
OCR_MAX_RETRIES=3
# Minimum confidence threshold (0.0-1.0)
OCR_MIN_CONFIDENCE=0.0
# DPI for PDF rasterization (higher = better quality, slower)
OCR_DPI=300
# Preprocessing mode: auto (smart upscale), on (always), off (disable)
OCR_PREPROCESS_MODE=auto
# Target DPI for upscaling low-res scans
OCR_TARGET_DPI=400

# =============================================================================
# Sentry (اختياري — للمراقبة)
# =============================================================================
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# =============================================================================
# Cloudflare
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# =============================================================================
# Domains
# =============================================================================
DOMAIN="ibnalazhardocs.workers.dev"
NEXTAUTH_URL="https://ibnalazhardocs.workers.dev"
# رابط الموقع العام — يُستخدم في sitemap/robots/canonical/OpenGraph/روابط البريد
# تطابق قيمة SITE_URL في التطبيق (apps/web/src/lib/shared/constants.ts)
NEXT_PUBLIC_SITE_URL="https://ibnalazhardocs.com"
# رابط التطبيق (APP_URL) — تقرأه خدمة web في docker-compose.yml
APP_URL="https://ibnalazhardocs.com"

# =============================================================================
# OpenTelemetry (اختياري)
# =============================================================================
OTEL_ENABLED="false"
OTEL_EXPORTER_OTLP_ENDPOINT=""

# =============================================================================
# Next.js
# =============================================================================
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"

# =============================================================================
# المراقبة (Prometheus)
# يجب أن يطابق هذا الرمز القيمة المعيّنة لخدمة web (PROMETHEUS_BEARER_TOKEN)
# ويُستخدم في infrastructure/monitoring/prometheus.yml لاستعلام /api/metrics/prometheus
# ولّد القيمة: openssl rand -base64 32
# =============================================================================
PROMETHEUS_BEARER_TOKEN=
